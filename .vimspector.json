{
    "configurations": {
        "Vim - run a test": {
            "adapter": "vscode-cpptools",
            "configuration": {
                "type": "cppdbg",
                "request": "launch",
                "program": "${workspaceRoot}/install/bin/nvim",
                "args": ["-u", "mini.vim"],
                "cwd": "${workspaceRoot}",
                "environment": [],
                "externalConsole": true,
                "stopAtEntry": true,
                "MIMode": "gdb",
                "logging": {
                    "engineLogging": false
                }
            }
        }
    }
}
